# Copy this file to .env or inject these values through your MCP client configuration.
# Never commit real API keys.
KCSC_API_KEY=your_kcsc_api_key
LAW_API_KEY=your_law_openapi_oc_key

# Optional: folder containing 상수도설계기준_해설편(2023).md and/or 하수도설계기준_해설편(2020).md
REFERENCE_DIR=/absolute/path/to/reference/manuals
